# ------------------------------------------------------------------
# YWCA backend environment variables
# Copy to .env and fill in real values. .env is gitignored.
# ------------------------------------------------------------------

# --- Server ---
PORT=5050
NODE_ENV=development
FRONTEND_URL=https://your-production-url.example
FRONTEND_URL_DEV=http://localhost:5174
API_URL=http://localhost:5050

# --- Firebase Authentication (entire service-account JSON on one line) ---
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"..."}'

# --- Database (Supabase / PostgreSQL) ---
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres

# --- SMTP (Gmail for transactional email) ---
SMTP_USER=ywca.disc@gmail.com
SMTP_PASS=<gmail-app-password>
SMTP_FROM=ywca.disc@gmail.com
SMTP_FROM_NAME=YWCA Evanston/North Shore

# --- AWS S3 (for /uploads route — images and PDFs) ---
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=<access-key-id-from-IAM>
AWS_SECRET_ACCESS_KEY=<secret-access-key-from-IAM>
S3_BUCKET_NAME=ywca-ens-uploads
